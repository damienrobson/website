---
layout: layouts/base.njk
title: Case Studies
---

<header>
  <h1>Selected Work</h1>
  <p>A deep dive into the problems I've solved and the impact I've made.</p>
</header>

<div class="cases-grid">
  {% for study in collections.caseStudies | reverse %}
    <article class="case-card">
      <div class="case-card-content">
        <h3><a href="{{ study.url }}">{{ study.data.title }}</a></h3>
        <p class="case-role"><strong>Role:</strong> {{ study.data.role }}</p>
        <p>{{ study.data.summary }}</p>
        
        <div class="case-tags">
          {% for tool in study.data.tools %}
            <span class="tool-tag">{{ tool }}</span>
          {% endfor %}
        </div>
      </div>
    </article>
  {% endfor %}
</div>
