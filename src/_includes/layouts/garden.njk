---
layout: layouts/base.njk
---
<article class="garden-note">
  <header>
    <span class="badge badge-{{ maturity }}">
      {% if maturity == "seed" %}Seed
      {% elif maturity == "sapling" %}Sapling
      {% elif maturity == "evergreen" %}Evergreen
      {% endif %}
    </span>
    <h1>{{ title }}</h1>
    <p><em>Last tended: {{ page.date | postDate }}</em></p>
  </header>

  <div class="garden-content">
    {{ content | safe }}
  </div>

  <div class="garden-footer">
    <h4>About my Garden</h4>
    <p>This is a digital garden, not a blog. Notes range from rough ideas to polished thoughts.</p>
  </div>
</article>